from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

app = FastAPI()

# CORS Ayarlari - Browser baglantisi icin
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Veri Modelleri
class QueryModel(BaseModel):
    query: str
    owner: str

class AuthModel(BaseModel):
    platform: str
    username: str
    password: str

@app.get("/")
def home():
    return {"status": "ARCHERA SYSTEM ONLINE", "mode": "Shadow V4"}

# SORGULAMA MOTORU - Tamamen Ingilizce Karakterler
@app.post("/api/v4/sorgu")
async def run_osint(data: QueryModel):
    target_user = data.query.replace("@", "").strip()
    
    return {
        "status": "success",
        "targets": [
            {
                "username": target_user,
                "name": f"{target_user.capitalize()} Analiz Edildi",
                "location": "Suruc / Merkez",
                "leaks": [
                    {
                        "type": "Durum",
                        "data": "Baglanti Basarili"
                    },
                    {
                        "type": "Sistem",
                        "data": "Veri okuma islemi sorunsuz"
                    }
                ],
                "stories": [
                    "https://via.placeholder.com/150"
                ],
                "ai_report": f"{target_user} kullanicisi icin sistem stabil ve veri akisi aktif. ARCHERA v4 derin tarama modunda."
            }
        ]
    }

# YONETIM MERKEZI: HESAP BAGLAMA
@app.post("/api/v4/auth/link")
async def link_account(data: AuthModel):
    return {
        "status": "success",
        "message": f"{data.username} hesabi basariyla tunellendi."
    }
